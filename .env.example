# ────────────────────────────────────────────────
#  הגדרות סביבה — קובץ לדוגמה
#  העתק לקובץ .env ומלא בערכים האמיתיים שלך
#  cp .env.example .env
# ────────────────────────────────────────────────

# GitHub — Personal Access Token לדחיפת קוד
GITHUB_TOKEN=

# Anthropic — מפתח API לסוכנים
ANTHROPIC_API_KEY=

# יובל (מעצב התמונות) — מפתח API ליצירת תמונות
IMAGE_API_KEY=

# OpenAI — מפתח API לסקיל gpt-image-gen (יצירת תמונות ע"י יובל)
OPENAI_API_KEY=

# חן (החוקרת) — מפתח API לחיפוש/מחקר
RESEARCH_API_KEY=
